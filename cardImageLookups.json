{
    "provider": "scryfall",
    "usage": {
        "normalCards": {
            "fetch": "lookup_url",
            "imagePath": "image_uris.normal",
            "fallbackImagePath": "image_uris.large"
        },
        "doubleFacedCards": {
            "fetch": "lookup_url",
            "frontImagePath": "card_faces[0].image_uris.normal",
            "backImagePath": "card_faces[1].image_uris.normal"
        },
        "tokens": {
            "fetch": "lookup_url",
            "imagePath": "data[0].image_uris.normal",
            "note": "Token searches may return multiple printings. For MVP, use the first result or let the user choose."
        },
        "recommendedHeaders": {
            "Accept": "application/json",
            "User-Agent": "your-app-name/0.1 your-email-or-url"
        }
    },
